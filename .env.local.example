# --------------------------------------------------------------------
# Speetch — variables d'environnement (copier en .env.local et remplir)
# --------------------------------------------------------------------

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clé service-role — JAMAIS exposée côté client
SUPABASE_SERVICE_ROLE_KEY=

# Email du propriétaire de l'agence (gate /admin)
SPEETCH_OWNER_EMAIL=

# Pepper utilisé pour hasher les mots de passe des Espaces Clients
# Générer une chaîne aléatoire longue : openssl rand -base64 48
SPEETCH_CLIENT_PASSWORD_PEPPER=

# URL publique du site (utile pour les liens absolus / OG / e-mails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
